{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": [
      "vite/client",
      "@dcloudio/types"
    ],
    "baseUrl": "."
  },
  "include": [
    "env.d.ts",
    "main.ts",
    "App.vue",
    "pages/**/*.vue",
    "subpackages/**/*.vue",
    "src/**/*.ts",
    "src/**/*.vue"
  ]
}
