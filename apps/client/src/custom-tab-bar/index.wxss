/* ============================================================
 * 自定义 TabBar 样式（mp-weixin 原生 tabBar）
 * 视觉对齐青藤参考：
 *  - 高度 49px + 安全区
 *  - 激活态实心青绿色 #3FCF8E + 文字主色
 *  - 非激活态灰色 #9AA1AB
 *  - 文字 10/Medium
 *  - 背景毛玻璃 + 0.96 高不透明度 fallback（mp-weixin 兼容）
 * ============================================================ */

.tab-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  align-items: end;
  gap: 12rpx;
  padding: 18rpx 16rpx 16rpx;
  border: 1rpx solid rgba(63, 207, 142, 0.08);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 8rpx 32rpx rgba(63, 207, 142, 0.08), 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  /* mp-weixin 原生组件支持 backdrop-filter，H5 保留毛玻璃；背景已用 0.96 高不透明度近似降级 */
  backdrop-filter: blur(20rpx);
}

.tab-bar__item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
  min-height: 88rpx;
  padding: 8rpx 0;
  border: 0;
  background: transparent;
  /* 非激活态灰色对齐青藤参考 #9AA1AB */
  color: #9AA1AB;
  font-size: 20rpx;
  line-height: 1;
  transition: color 250ms cubic-bezier(0.4, 0, 0.2, 1), transform 250ms cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-bar__item:active {
  transform: scale(0.92);
}

/* 激活态文字主色：青藤绿 #3FCF8E */
.tab-bar__item--active {
  color: #3FCF8E;
}

.tab-bar__item--prominent {
  min-height: 112rpx;
  margin-top: -30rpx;
  padding: 14rpx 0 10rpx;
  border: 1rpx solid rgba(63, 207, 142, 0.18);
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(63, 207, 142, 0.10);
  transition: border-color 250ms ease, background 250ms ease, box-shadow 250ms ease, transform 250ms cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-bar__item--prominent:active {
  transform: scale(0.95);
}

.tab-bar__item--prominent.tab-bar__item--active {
  border-color: rgba(63, 207, 142, 0.35);
  background: rgba(232, 248, 240, 0.95);
  box-shadow: 0 6rpx 24rpx rgba(63, 207, 142, 0.20);
}

.tab-bar__icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1), background 250ms ease;
}

/* 激活态图标背景：青藤绿浅底 */
.tab-bar__item--active .tab-bar__icon-wrap {
  background: rgba(63, 207, 142, 0.10);
  transform: scale(1.08);
}

.tab-bar__item--prominent .tab-bar__icon-wrap {
  width: 72rpx;
  height: 72rpx;
}

.tab-bar__item--prominent.tab-bar__item--active .tab-bar__icon-wrap {
  background: rgba(63, 207, 142, 0.15);
  transform: scale(1.10);
}

.tab-bar__icon {
  width: 40rpx;
  height: 40rpx;
  transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-bar__item--active .tab-bar__icon {
  transform: scale(1.10);
}

.tab-bar__item--prominent .tab-bar__icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-bar__label {
  font-size: 20rpx;
  font-weight: 500;
  transition: font-weight 250ms ease;
}

.tab-bar__item--active .tab-bar__label {
  font-weight: 600;
}

/* 激活态指示条：青藤绿渐变 */
.tab-bar__indicator {
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  width: 32rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: linear-gradient(90deg, #3FCF8E 0%, #7CD9A6 100%);
  transform: translateX(-50%);
  animation: indicator-pop 350ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-bar__item--prominent .tab-bar__indicator {
  bottom: 8rpx;
}

@keyframes indicator-pop {
  0% {
    transform: translateX(-50%) scaleX(0);
    opacity: 0;
  }
  60% {
    transform: translateX(-50%) scaleX(1.2);
    opacity: 1;
  }
  100% {
    transform: translateX(-50%) scaleX(1);
    opacity: 1;
  }
}
